# ==================================
# SageLMS — Environment Variables
# ==================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git!

# ---- Database (PostgreSQL + pgvector) ----
POSTGRES_DB=sagelms
POSTGRES_USER=sagelms
POSTGRES_PASSWORD=sagelms
POSTGRES_PORT=5432

# ---- pgAdmin (Database UI) ----
PGADMIN_DEFAULT_EMAIL=admin@sagelms.dev
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ---- JWT ----
JWT_SECRET=change_me
JWT_EXPIRES_IN=3600

# ---- AI / LLM ----
GOOGLE_API_KEY=<your-google-gemini-api-key-here>
GOOGLE_MODEL=gemini-3.0-flash
AI_TUTOR_TEMPERATURE=0.2
AI_TUTOR_MAX_OUTPUT_TOKENS=1024

# ---- Observability ----
# LOG_LEVEL=info
# OTEL_EXPORTER_ENDPOINT=http://localhost:4317
